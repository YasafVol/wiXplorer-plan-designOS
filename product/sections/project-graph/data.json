{
  "_meta": {
    "models": {
      "GraphNode": "A single entity node in the graph. Has a type (page, app, table, code, analytics), a label, source system, type-specific metadata, and an alert count. All nodes have an id that is referenced by edges.",
      "GraphEdge": "A directed connection between two nodes. The source and target fields reference node ids. The type describes the nature of the relationship (e.g. hosts, manages, depends_on). Edges with hasAlert=true are rendered in red.",
      "Alert": "An active monitoring signal attached to a specific node. Severity can be error, warning, or info. Each alert references the nodeId of the affected entity.",
      "LayerFilter": "A UI filter toggle for a given entity type. When enabled is false the entire layer is hidden from the graph."
    },
    "relationships": [
      "Project node (type=project) is the root — edges of type 'contains' connect it to all top-level pages and site-level apps",
      "Pages connect to apps they host via edges of type 'hosts'",
      "Apps connect to tables they manage via edges of type 'manages'",
      "Apps connect to pages they auto-generate (e.g. blog articles, store cart/checkout) via edges of type 'manages'",
      "Pages connect to tables they consume directly via edges of type 'reads'",
      "Pages connect to code files via edges of type 'contains'",
      "Code files connect to tables they read/write via edges of type 'reads'",
      "Code files connect to other code files they import via edges of type 'depends_on'",
      "Analytics nodes connect to their page via edges of type 'tracks'",
      "Alerts reference a nodeId — any edge incident to that node gains hasAlert=true"
    ]
  },

